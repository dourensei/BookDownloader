# ==================== Python 通用忽略 ====================
# 字节码文件
__pycache__/
*.py[cod]
*$py.class

# Python编译文件
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
venv/
env/
ENV/
.venv/
.env/

# ==================== 项目专属忽略 ====================
# 日志文件目录（自动生成，无需提交）
logs/

# PyInstaller 打包生成的文件（exe相关）
build/
dist/
*.spec
*.exe
*.exe.manifest
*.pdb

# 日志文件（兜底，防止单日志文件未被目录过滤）
*.log
*.log.*

# ==================== 开发工具/系统忽略 ====================
# IDE配置文件
.idea/
.vscode/
*.swp
*.swo
.DS_Store  # Mac系统隐藏文件
Thumbs.db  # Windows系统缩略图缓存
*.bak      # 备份文件
*.tmp      # 临时文件

# 环境变量配置（如需提交请注释此行，建议本地存放敏感配置）
.env
.env.local

# 其它
cache
download
patch
/requirements.txt
